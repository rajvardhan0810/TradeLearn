<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" integrity="sha512-Kc323vGBEqzTmouAECnVceyQqyqdsSiqLQISBL29aUW4U/M7pSPA/gEUZQqv1cwx4OnYxTxve5UMg5GT6L4JJg==" crossorigin="anonymous" referrerpolicy="no-referrer" />
</head>
<body class="bg-gray-200 h-screen flex items-center justify-center">
    <div class="absolute top-4 left-4">
        <button class="bg-green-500 hover:bg-green-600 text-white font-bold py-2 px-4 rounded">
            <a href="/home">home</a>
        </button>
    </div>
    <div class="absolute top-5 right-5">
        <a
          class="bg-red-500 px-6 py-2 text-sm text-white inline-block rounded-md"
          href="/"
          >Logout</a>
    </div>
    
    <div class="bg-white p-8 rounded-lg shadow-md max-w-sm w-full text-center">
        <div class="bg-white p-8 rounded-lg shadow-md max-w-sm w-full text-center">
            <div class="mt-5">
              <form
                action="/update-profile-pic"
                method="POST"
                enctype="multipart/form-data"
                class="flex flex-col items-center justify-center"
              >
                <!-- Preview the uploaded image -->
                <img
                  id="uploadedImagePreview"
                  src="/uploads/<%= result.profilePic %>"
                  class="w-24 h-24 rounded-full border-2 border-blue-500 mb-3"
                />
            
                <!-- Upload icon for choosing a new image -->
                <label
                  for="profilePic"
                  class="absolute mt-20 ml-12 bg-zinc-700 text-white w-8 h-8 text-sm rounded-full cursor-pointer flex items-center justify-center hover:bg-zinc-800 transform -translate-x-2 -translate-y-2"
                >
                  <i class="fas fa-upload"></i>
                </label>
                <input
                  type="file"
                  name="profilePic"
                  id="profilePic"
                  accept="image/*"
                  class="hidden"
                  onchange="previewImage(event)"
                />
            
                <!-- Submit button -->
               
              </form>
            </div>
            
            <script>
              // Function to preview the uploaded image
              function previewImage(event) {
                const file = event.target.files[0];
                if (file) {
                  const reader = new FileReader();
                  reader.onload = function (e) {
                    document.getElementById('uploadedImagePreview').src = e.target.result;
                  };
                  reader.readAsDataURL(file);
                }
              }
            </script>
        <div class="flex flex-col items-center">
           
                
            <h2 class="text-2xl font-bold mb-2 font-mono"><%= result.name %></h2>
            <p class="text-gray-600 mb-4 font-mono"><%= result.email %></p>
            <div class="mb-4">
                <% if (result.github) { %>
                    <a href="<%= result.linkedin %>" class="text-blue-500 hover:underline flex items-center" target="_blank">
                        <i class="fa-brands fa-linkedin mr-2"></i>linkedin Profile
                    </a>
                <% } else { %>
                    <p class="text-gray-400">No linkedin Profile available</p>
                <% } %>
            </div>
            <div class="mb-6">
                <% if (result.github) { %>
                    <a href="<%= result.github %>" class="text-blue-500 hover:underline flex items-center" target="_blank">
                        <i class="fa-brands fa-github mr-2"></i>GitHub Profile
                    </a>
                <% } else { %>
                    <p class="text-gray-400">No GitHub Profile available</p>
                <% } %>
        </div>
        <div class="text-left mb-6">
            <h3 class="text-xl font-semibold mb-2 text-center font-mono">Skill</h3>
            <ul class="space-y-2">
                <li class="bg-gray-100 text-gray-700 font-bold py-2 rounded-md text-center"><%= result.skill %></li>
            </ul>
        </div>
        <div class="">
            <button class="bg-yellow-600 hover:bg-yellow-700 text-white font-bold py-2 px-4 rounded focus:outline-none focus:ring-2 focus:ring-red-500">
                <a  href="/updateuser">Update Account</a>
            </button>
            <button class="bg-red-600 mt-3 hover:bg-red-700 text-white font-bold py-2 px-4 rounded focus:outline-none focus:ring-2 focus:ring-red-500">
                <a  href="/userdelete">Delete Account</a>
            </button>
        </div>
    </div>
</body>
</html>
