<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" integrity="sha512-Kc323vGBEqzTmouAECnVceyQqyqdsSiqLQISBL29aUW4U/M7pSPA/gEUZQqv1cwx4OnYxTxve5UMg5GT6L4JJg==" crossorigin="anonymous" referrerpolicy="no-referrer" />
</head>
<body class="min-h-screen bg-gradient-to-br from-zinc-900 via-zinc-800 to-slate-900 text-white flex items-center justify-center p-4">
    <% const profileImageSrc = result.profilePic && result.profilePic !== "dummyUser.jpg" ? "/uploads/" + result.profilePic : "/images/dummyUser.jpg"; %>

    <div class="absolute top-4 left-4">
        <a href="/home" class="inline-flex items-center gap-2 bg-emerald-500 hover:bg-emerald-600 text-white font-semibold py-2 px-4 rounded-lg transition">
            <i class="fa-solid fa-house"></i>
            Home
        </a>
    </div>

    <div class="absolute top-4 right-4">
        <a href="/logout" class="inline-flex items-center gap-2 bg-rose-500 hover:bg-rose-600 text-white font-semibold py-2 px-4 rounded-lg transition">
            <i class="fa-solid fa-right-from-bracket"></i>
            Logout
        </a>
    </div>

    <main class="w-full max-w-md rounded-2xl bg-zinc-900/80 backdrop-blur-md border border-zinc-700 p-8 shadow-2xl">
        <section class="flex flex-col items-center">
            <div class="relative">
                <img
                    id="uploadedImagePreview"
                    src="<%= profileImageSrc %>"
                    alt="Profile Picture"
                    class="w-28 h-28 rounded-full border-4 border-cyan-400 object-cover shadow-lg"
                />

                <form action="/update-profile-pic" method="POST" enctype="multipart/form-data" id="profileUploadForm">
                    <label
                        for="profilePic"
                        class="absolute -bottom-1 -left-1 bg-cyan-500 text-white w-10 h-10 rounded-full cursor-pointer flex items-center justify-center hover:bg-cyan-600 border-2 border-zinc-900"
                        title="Upload profile picture"
                    >
                        <i class="fas fa-camera"></i>
                    </label>
                    <input
                        type="file"
                        name="profilePic"
                        id="profilePic"
                        accept="image/*"
                        class="hidden"
                    />
                </form>

                <form action="/remove-profile-pic" method="POST">
                    <button
                        type="submit"
                        class="absolute -top-1 -right-1 bg-rose-500 text-white w-10 h-10 rounded-full cursor-pointer flex items-center justify-center hover:bg-rose-600 border-2 border-zinc-900"
                        title="Remove profile picture"
                    >
                        <i class="fa-solid fa-trash"></i>
                    </button>
                </form>
            </div>

            <h2 class="text-2xl font-bold mt-5"><%= result.name %></h2>
            <p class="text-zinc-300 mb-5"><%= result.email %></p>
        </section>

        <section class="space-y-3">
            <div class="rounded-xl bg-zinc-800 p-3">
                <p class="text-xs uppercase tracking-wide text-zinc-400">Skill</p>
                <p class="font-semibold text-cyan-300 mt-1"><%= result.skill %></p>
            </div>

            <div class="rounded-xl bg-zinc-800 p-3">
                <p class="text-xs uppercase tracking-wide text-zinc-400 mb-2">Social Links</p>
                <% if (result.linkedin) { %>
                    <a href="<%= result.linkedin %>" class="text-blue-400 hover:underline block" target="_blank">
                        <i class="fa-brands fa-linkedin mr-2"></i>LinkedIn Profile
                    </a>
                <% } else { %>
                    <p class="text-zinc-500">No LinkedIn profile added</p>
                <% } %>

                <% if (result.github) { %>
                    <a href="<%= result.github %>" class="text-blue-400 hover:underline block mt-2" target="_blank">
                        <i class="fa-brands fa-github mr-2"></i>GitHub Profile
                    </a>
                <% } else { %>
                    <p class="text-zinc-500 mt-2">No GitHub profile added</p>
                <% } %>
            </div>
        </section>

        <section class="mt-6 grid grid-cols-1 sm:grid-cols-2 gap-3">
            <a href="/updateuser" class="text-center bg-amber-500 hover:bg-amber-600 text-white font-semibold py-2 px-4 rounded-lg transition">
                Update Account
            </a>
            <a href="/userdelete" class="text-center bg-rose-600 hover:bg-rose-700 text-white font-semibold py-2 px-4 rounded-lg transition">
                Delete Account
            </a>
        </section>
    </main>

    <script>
        const profilePicInput = document.getElementById("profilePic");
        const preview = document.getElementById("uploadedImagePreview");
        const uploadForm = document.getElementById("profileUploadForm");

        profilePicInput.addEventListener("change", (event) => {
            const file = event.target.files[0];
            if (!file) {
                return;
            }

            const reader = new FileReader();
            reader.onload = function (e) {
                preview.src = e.target.result;
            };
            reader.readAsDataURL(file);

            uploadForm.submit();
        });
    </script>
</body>
</html>
