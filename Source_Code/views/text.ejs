<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TradeLearn Platform - Messages</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" integrity="sha512-Kc323vGBEqzTmouAECnVceyQqyqdsSiqLQISBL29aUW4U/M7pSPA/gEUZQqv1cwx4OnYxTxve5UMg5GT6L4JJg==" crossorigin="anonymous" referrerpolicy="no-referrer" />
</head>
<body class="min-h-screen bg-gradient-to-br from-zinc-950 via-zinc-900 to-zinc-800 text-white">
    <main class="max-w-4xl mx-auto h-screen flex flex-col p-3 sm:p-5">
        <header class="rounded-2xl border border-zinc-700 bg-zinc-900/70 px-4 py-3 flex items-center justify-between">
            <a href="/PersonalMessages" class="inline-flex items-center gap-2 bg-zinc-700 hover:bg-zinc-600 px-3 py-2 rounded-lg text-sm">
                <i class="fa-solid fa-arrow-left"></i>
                Chats
            </a>
            <div class="text-center">
                <p class="text-xs text-zinc-400">Conversation with</p>
                <h1 class="text-lg sm:text-xl font-bold text-cyan-300 break-all"><%= username %></h1>
            </div>
            <a href="/home" class="inline-flex items-center gap-2 bg-cyan-600 hover:bg-cyan-500 px-3 py-2 rounded-lg text-sm">
                <i class="fa-solid fa-house"></i>
                Home
            </a>
        </header>

        <section id="messageContainer" class="flex-1 mt-4 rounded-2xl border border-zinc-700 bg-zinc-900/70 p-4 overflow-y-auto">
            <% if (usermessage.length === 0) { %>
                <div class="h-full flex flex-col items-center justify-center text-zinc-400 text-center">
                    <i class="fa-regular fa-comment-dots text-5xl text-cyan-400"></i>
                    <p class="mt-4">No messages yet. Say hi and start the conversation.</p>
                </div>
            <% } %>

            <div class="space-y-3">
                <% usermessage.forEach(item => { %>
                    <% const dividerIndex = item.indexOf(":"); %>
                    <% const sender = dividerIndex === -1 ? "" : item.slice(0, dividerIndex).trim(); %>
                    <% const messageText = dividerIndex === -1 ? item : item.slice(dividerIndex + 1).trim(); %>
                    <% const isMine = sender.toLowerCase() === currentUser.toLowerCase(); %>

                    <article class="w-full flex <%= isMine ? 'justify-end' : 'justify-start' %>">
                        <div class="<%= isMine ? 'bg-cyan-600 text-white' : 'bg-zinc-700 text-zinc-100' %> max-w-[85%] sm:max-w-[70%] rounded-2xl px-4 py-3 shadow">
                            <p class="text-xs <%= isMine ? 'text-cyan-100' : 'text-zinc-300' %> mb-1 font-semibold">
                                <%= sender || username %>
                            </p>
                            <p class="break-words"><%= messageText %></p>
                        </div>
                    </article>
                <% }) %>
            </div>
        </section>

        <form action="/text/<%= username %>" method="post" class="mt-4 rounded-2xl border border-zinc-700 bg-zinc-900/70 p-3 flex items-center gap-3">
            <input
                type="text"
                name="text"
                placeholder="Type a message..."
                required
                autocomplete="off"
                class="flex-1 bg-zinc-800 border border-zinc-700 rounded-xl px-4 py-3 outline-none focus:ring-2 focus:ring-cyan-400"
            />
            <button type="submit" class="bg-cyan-600 hover:bg-cyan-500 px-4 py-3 rounded-xl font-semibold">
                <i class="fa-solid fa-paper-plane"></i>
            </button>
        </form>
    </main>

    <script>
        const messageContainer = document.getElementById("messageContainer");
        if (messageContainer) {
            messageContainer.scrollTop = messageContainer.scrollHeight;
        }
    </script>
</body>
</html>
